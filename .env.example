# Supabase (mesmo projeto do onlyfit v1 — dados reais).
# No desktop/Next às vezes aparece como NEXT_PUBLIC_SUPABASE_URL /
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY — aqui o prefixo é VITE_.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Domínio base usado nos links de e-mail (confirmação de cadastro e reset de
# senha — edge functions send-signup-confirmation e send-password-reset).
# Preencha no deploy com a origem pública da app (ex.: https://mobile.onlyfitapp.com).
# Vazio/ausente => o cliente usa o fallback público https://mobile.onlyfitapp.com.
# Só domínios da allowlist das edge functions são aceitos (senão cai no padrão).
VITE_APP_BASE_URL=

# Versão enviada nos payloads de integrações nativas, como Apple Health.
# Opcional; se vazio, o app usa "mobile-web".
VITE_APP_VERSION=
